  "dataStorage": {
    "method": "supabase",
    "tableName": "customer_feedback",
    "fields": [
      "id",
      "ticket_id",
      "feedback_type",
      "name",
      "phone",
      "email",
      "wechat",
      "subject",
      "content",
      "preferred_contact",
      "expected_time",
      "attachments",
      "status",
      "priority",
      "assigned_to",
      "response_content",
      "response_time",
      "created_at",
      "updated_at"
    ],
    "status": "已创建",
    "rlsPolicy": "允许匿名用户提交和查询"
  },
  "supabaseConfig": {
    "endpoint": "https://coplhkyergcwuonyfjyd.supabase.co/functions/v1/customer-feedback",
    "table": "customer_feedback",
    "method": "POST",
    "functionName": "customer-feedback",
    "headers": {
      "Content-Type": "application/json",
      "Prefer": "return=representation"
    },
    "dataMapping": {
      "ticket_id": "自动生成TK-前缀+时间戳+随机数",
      "feedback_type": "用户选择的反馈类型",
      "name": "用户输入的姓名",
      "phone": "用户输入的联系电话",
      "email": "用户输入的邮箱",
      "wechat": "用户输入的微信号",
      "subject": "用户输入的咨询主题",
      "content": "用户输入的详细内容",
      "preferred_contact": "用户选择的偏好联系方式",
      "expected_time": "用户选择的期望回复时间",
      "status": "submitted",
      "priority": "根据feedback_type自动映射"
    },
    "priorityMapping": {
      "general": "normal",
      "booking": "high",
      "complaint": "urgent",
      "cooperation": "normal",
      "recruitment": "normal",
      "lost-found": "high",
      "vip": "urgent"
    }
  },
  "notifications": {
    "sms": {
