{
  "systemName": "杭州滨江开元名都大酒店客户反馈系统",
  "version": "1.0",
  "feedbackTypes": [
    {
      "id": "general",
      "name": "一般咨询",
      "description": "酒店服务、设施、政策等一般性问题",
      "priority": "normal",
      "responseTime": "24小时内"
    },
    {
      "id": "booking",
      "name": "预订咨询",
      "description": "客房预订、会议场地、婚宴预订等",
      "priority": "high",
      "responseTime": "2小时内"
    },
    {
      "id": "complaint",
      "name": "投诉建议",
      "description": "服务投诉、改进建议、问题反馈",
      "priority": "urgent",
      "responseTime": "1小时内"
    },
    {
      "id": "cooperation",
      "name": "商务合作",
      "description": "商务合作、团购、协议价、异业合作",
      "priority": "normal",
      "responseTime": "24小时内"
    },
    {
      "id": "recruitment",
      "name": "人才招聘",
      "description": "招聘信息、简历投递、实习申请",
      "priority": "normal",
      "responseTime": "3个工作日内"
    },
    {
      "id": "lost-found",
      "name": "失物招领",
      "description": "遗失物品查询、招领登记",
      "priority": "high",
      "responseTime": "2小时内"
    },
    {
      "id": "vip",
      "name": "VIP专属",
      "description": "VIP客户专属服务通道",
      "priority": "urgent",
      "responseTime": "30分钟内"
    }
  ],
  "formConfig": {
    "fields": [
      {
        "name": "feedbackType",
        "label": "咨询类型",
        "type": "select",
        "required": true,
        "placeholder": "请选择咨询类型",
        "options": [
          { "value": "general", "label": "一般咨询" },
          { "value": "booking", "label": "预订咨询" },
          { "value": "complaint", "label": "投诉建议" },
          { "value": "cooperation", "label": "商务合作" },
          { "value": "recruitment", "label": "人才招聘" },
          { "value": "lost-found", "label": "失物招领" },
          { "value": "vip", "label": "VIP专属" }
        ]
      },
      {
        "name": "name",
        "label": "您的姓名",
        "type": "text",
        "required": true,
        "placeholder": "请输入您的姓名",
        "validation": "至少2个字符"
      },
      {
        "name": "phone",
        "label": "联系电话",
        "type": "tel",
        "required": true,
        "placeholder": "请输入手机号码",
        "validation": "请输入有效的11位手机号码"
      },
      {
        "name": "email",
        "label": "电子邮箱",
        "type": "email",
        "required": false,
        "placeholder": "请输入邮箱（选填）"
      },
      {
        "name": "wechat",
        "label": "微信号",
        "type": "text",
        "required": false,
        "placeholder": "请输入微信号（选填）"
      },
      {
        "name": "subject",
        "label": "咨询主题",
        "type": "text",
        "required": true,
        "placeholder": "请简要描述您的需求",
        "maxLength": 50
      },
      {
        "name": "content",
        "label": "详细内容",
        "type": "textarea",
        "required": true,
        "placeholder": "请详细描述您的需求、问题或建议...",
        "maxLength": 1000,
        "rows": 6
      },
      {
        "name": "preferredContact",
        "label": "偏好联系方式",
        "type": "select",
        "required": false,
        "placeholder": "请选择联系方式",
        "options": [
          { "value": "phone", "label": "电话" },
          { "value": "wechat", "label": "微信" },
          { "value": "email", "label": "邮件" }
        ],
        "default": "phone"
      },
      {
        "name": "expectedTime",
        "label": "期望回复时间",
        "type": "select",
        "required": false,
        "placeholder": "请选择期望回复时间",
        "options": [
          { "value": "asap", "label": "尽快" },
          { "value": "today", "label": "今天内" },
          { "value": "tomorrow", "label": "明天" },
          { "value": "week", "label": "一周内" }
        ]
      },
      {
        "name": "attachments",
        "label": "附件上传",
        "type": "file",
        "required": false,
        "accept": "image/*,.pdf,.doc,.docx",
        "maxSize": "5MB",
        "maxCount": 3,
        "description": "支持图片、PDF、Word文档，最多3个文件"
      }
    ],
    "submitButton": {
      "text": "提交反馈",
      "loadingText": "提交中...",
      "successText": "提交成功"
    }
  },
  "successMessage": {
    "title": "提交成功！",
    "content": "感谢您联系杭州滨江开元名都大酒店，我们已收到您的反馈，将尽快安排专人与您联系。",
    "ticketNumber": "您的反馈编号：{ticketId}",
    "actions": [
      { "type": "button", "text": "查看反馈状态", "action": "viewStatus" },
      { "type": "button", "text": "返回首页", "action": "goHome" }
    ]
  },
  "contactChannels": {
