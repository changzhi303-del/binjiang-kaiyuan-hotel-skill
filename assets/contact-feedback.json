      "customerTemplate": "【杭州滨江开元名都大酒店】尊敬的{name}，您的反馈已收到，反馈编号：{ticketId}。我们将尽快安排专人与您联系，感谢您的支持！",
      "staffTemplate": "【酒店提醒】收到新的客户反馈，类型：{type}，主题：{subject}，请尽快处理。"
    },
    "wechat": {
      "enabled": true,
      "template": ""
    },
    "email": {
      "enabled": true,
      "customerSubject": "【杭州滨江开元名都大酒店】反馈确认",
      "customerTemplate": ""
    }
  },
  "workflow": {
