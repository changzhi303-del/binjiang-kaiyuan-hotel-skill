      { "step": 1, "name": "提交反馈", "status": "submitted", "description": "客户提交反馈表单" },
      { "step": 2, "name": "自动分配", "status": "assigned", "description": "系统根据类型自动分配给相关部门" },
      { "step": 3, "name": "处理中", "status": "processing", "description": "工作人员处理反馈" },
      { "step": 4, "name": "回复客户", "status": "responded", "description": "联系客户并回复处理结果" },
